{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Barwaaqo Skills (API + Frontend)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "echo Open https://nawal-mohamed18.github.io/barwaaqo-skills/ after deploy."],
      "preLaunchTask": "Run Barwaaqo Skills (API + Frontend)"
    },
    {
      "name": "Django API only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": ["runserver", "8765"],
      "django": true,
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe"
    }
  ]
}
